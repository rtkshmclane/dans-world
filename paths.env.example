# Dan's World -- App Source Paths
# Copy to paths.env and set paths for your machine.
# This file is .gitignored -- each developer/server has their own.
#
# On a dev Mac (e.g., Sam's):
#   Paths point to CTOWorkspace subdirs or ~/prototypes/
#
# On the server:
#   Paths point to /opt/app-sources/<name> (populated by scripts/sync-sources.sh)

