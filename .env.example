# Dan's World of AI Magic -- Environment Configuration
# Copy to .env and fill in values before deploying

# Secret key for signing JWT session cookies (generate with: openssl rand -hex 32)
AUTH_SECRET=changeme-generate-a-real-secret

# Default admin password (change after first login)
ADMIN_PASSWORD=changeme

# Host settings
HOST_DOMAIN=localhost
SSL_ENABLED=false

# Memory limits (adjust based on Proxmox VM size)
# 16GB host: apps=4g, admin=512m
# 32GB host: apps=8g, admin=1g
APPS_MEMORY_LIMIT=4g
ADMIN_MEMORY_LIMIT=512m
GATEWAY_MEMORY_LIMIT=128m
